{
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendPath": "../dist",
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "identifier": "de.calculum.romanum",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "productName": "CALCULUM ROMANUM",
  "version": "1.0.0",
  "identifier": "de.calculum.romanum",
  "plugins": null,
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "CALCULUM ROMANUM",
        "width": 800,
        "height": 600,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}
